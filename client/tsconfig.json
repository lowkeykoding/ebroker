{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "paths": {
      "@spartan-ng/helm/button": [
        "./src/lib/spartan/button/src/index.ts"
      ],
      "@spartan-ng/helm/card": [
        "./src/lib/spartan/card/src/index.ts"
      ],
      "@spartan-ng/helm/utils": [
        "./src/lib/spartan/utils/src/index.ts"
      ],
      "@spartan-ng/helm/sheet": [
        "./src/lib/spartan/sheet/src/index.ts"
      ],
      "@spartan-ng/helm/icon": [
        "./src/lib/spartan/icon/src/index.ts"
      ],
      "@spartan-ng/helm/calendar": [
        "./src/lib/spartan/calendar/src/index.ts"
      ],
      "@spartan-ng/helm/select": [
        "./src/lib/spartan/select/src/index.ts"
      ]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "typeCheckHostBindings": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    }
  ]
}
